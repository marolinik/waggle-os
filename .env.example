# API keys — set these via the UI (Settings > API Keys) which stores them in the vault.
# Only set here for CI/headless environments where the UI isn't available.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# LiteLLM proxy master key
LITELLM_MASTER_KEY=sk-waggle-dev

# LiteLLM proxy URL (for multi-model routing)
LITELLM_BASE_URL=http://localhost:4000

# Embedding model (for hybrid search - Task 0.6)
# Options: local (Xenova/bge-m3), openai (text-embedding-3-small)
EMBEDDING_PROVIDER=local

# M3 Server Configuration
DATABASE_URL=postgres://waggle:waggle_dev@localhost:5434/waggle
REDIS_URL=redis://localhost:6381
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
PORT=3100
CORS_ORIGIN=http://localhost:8080
