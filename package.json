{
  "name": "waggle-os",
  "version": "0.1.0",
  "description": "Waggle OS — workspace-native AI agent platform with persistent memory",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "app",
    "apps/*",
    "packages/*",
    "sidecar"
  ],
  "scripts": {
    "dev:web": "npm run --workspace=@waggle/web dev",
    "dev:server": "npm run --workspace=@waggle/server dev",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run --workspace=@waggle/web build",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:web": "npm run --workspace=@waggle/web test",
    "test:watch": "vitest"
  },
  "author": "Marko Markovic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marolinik/waggle-os.git"
  },
  "keywords": [
    "ai",
    "agent",
    "swarm",
    "memory",
    "llm",
    "waggle"
  ],
  "devDependencies": {
    "@swc/core-win32-x64-msvc": "^1.15.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^20.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
