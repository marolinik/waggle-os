{
  "name": "waggle-os",
  "version": "0.1.0",
  "description": "Waggle OS — workspace-native AI agent platform with persistent memory",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npx vite",
    "build": "cd apps/web && npx vite build --outDir ../../dist --emptyOutDir",
    "build:dev": "cd apps/web && npx vite build --mode development --outDir ../../dist --emptyOutDir",
    "preview": "cd apps/web && npx vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Marko Markovic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marolinik/waggle-os.git"
  },
  "keywords": [
    "ai",
    "agent",
    "swarm",
    "memory",
    "llm",
    "waggle"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^20.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1"
  }
}
